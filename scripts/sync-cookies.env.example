# sync-cookies.sh / sync-cookies.ps1 icin ayarlar
# Kopyala: cp scripts/sync-cookies.env.example scripts/sync-cookies.env

# Sunucu SSH (kullanici@ip)
REMOTE=root@SUNUCU_IP

# Sunucudaki cookie dosya yolu
REMOTE_PATH=/root/videocutter/videocutter/cookies.txt

# Bilgisayarindaki cookie dosyasi (bos = proje kokundeki cookies.txt)
# LOCAL_COOKIES=C:\Users\sen\Downloads\cookies.txt

# Yukleme sonrasi sunucuda calistirilacak komut (opsiyonel)
RESTART_CMD=cd /root/videocutter/videocutter && pkill -f 'python3 app.py' || true && source .venv/bin/activate && set -a && source .env && set +a && nohup python3 app.py >> app.log 2>&1 &
