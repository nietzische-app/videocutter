OPENAI_API_KEY=sk-your-key-here
GPT_MODEL=gpt-4o-mini
WHISPER_MODEL=whisper-1
WHISPER_LANGUAGE=tr

# ── Otomatik pilot (scheduler) ──────────────────────────────
# true yapinca sistem kendi kendine calisir, elle mudahale gerekmez
SCHEDULER_ENABLED=true

# Cron: dakika saat gun ay haftanin_gunu
# Asagisi = her gun saat 10:00 ve 18:00
SCHEDULER_CRON=0 10,18 * * *

# Cron bos birakilirsa kac saatte bir calissin:
# SCHEDULER_INTERVAL_HOURS=12

SCHEDULER_TIMEZONE=Europe/Istanbul
SCHEDULER_CATEGORIES=comedy,film,football,roblox,foodporn,streamer
SCHEDULER_VIDEOS_PER_CATEGORY=1
SCHEDULER_MAX_PER_RUN=6
SCHEDULER_CLIP_SECONDS=30
SCHEDULER_AUTO_UPLOAD=true
SCHEDULER_RUN_ON_START=true

# ── YouTube otomatik yukleme ────────────────────────────────
YOUTUBE_CLIENT_SECRETS=client_secrets.json
YOUTUBE_TOKEN_PATH=youtube_token.json
YOUTUBE_PRIVACY=public
